rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if false;
      allow update: if request.auth != null && (
        // ALLOW BOOSTER UPDATES:
        // We allow updating the 'teams' map. In a production environment with 
        // per-user identity, we would check request.auth.uid here.
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['teams']) ||
        
        // ADMIN / POLLER UPDATES:
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'teams', 'stats', 'locked', 'revealed', 'xiReady', 'matchStatus',
          'score', 'matchEnded', 'players', 'playerStatus', 'currentBatsmen',
          'currentBowler', 'matchResult', 'abandoned', 'finalized',
          'tossResult', 'overSummaries', 'label', 'liveMatchId',
          't1', 't2', 't1img', 't2img', 'isIPL', 'matchType',
          'matchNum', 'fantasyEnabled', 'createdAt', 'venue'
        ])
      );
    }

    match /meta/game {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    match /meta/members {
      allow read: if request.auth != null;
      allow update: if request.auth != null; // Allow members to join/update profiles
    }

    match /meta/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    match /season/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
