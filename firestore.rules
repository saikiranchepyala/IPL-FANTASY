rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if false;
      allow update: if request.auth != null && (
        // 1. ADMIN OVERRIDE (using custom claims)
        request.auth.token.admin == true ||
        
        // 2. ALLOW BOOSTER UPDATES (by members)
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['teams']) ||
        
        // 3. ADMIN / POLLER UPDATES (Fallback logic if token not yet set)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'teams', 'stats', 'locked', 'revealed', 'xiReady', 'matchStatus',
          'score', 'matchEnded', 'players', 'playerStatus', 'currentBatsmen',
          'currentBowler', 'matchResult', 'abandoned', 'finalized',
          'tossResult', 'overSummaries', 'label', 'liveMatchId',
          't1', 't2', 't1img', 't2img', 'isIPL', 'matchType',
          'matchNum', 'fantasyEnabled', 'createdAt', 'venue'
        ])
      );
    }

    match /meta/game {
      allow read: if request.auth != null;
      // Allow admin updates (like match ID rotation and activeMatchIds updates during finalize)
      allow write: if request.auth != null; 
    }

    match /meta/members {
      allow read: if request.auth != null;
      allow update: if request.auth != null; 
    }

    match /meta/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /season/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Allow saving totals during finalize
    }
  }
}
